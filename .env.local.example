# AgentHQ Environment Variables
# Copy this to .env.local and fill in your values
# OR just run: bash setup.sh sqlite (generates everything automatically)

# Database mode: "sqlite" or "supabase"
DB_MODE=sqlite

# SQLite path (only used when DB_MODE=sqlite)
SQLITE_PATH=./data/agenthq.db

# Supabase (only used when DB_MODE=supabase)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_KEY=eyJ...

# Auth (generated by setup.sh -- or set your own)
AUTH_PASSWORD=changeme
AUTH_SECRET=random-32-char-hex-string

# Optional: Gateway WebSocket (for live agent status from OpenClaw gateway)
# GATEWAY_WS_URL=ws://127.0.0.1:18789
# GATEWAY_AUTH_TOKEN=your-gateway-token
# GATEWAY_ORIGIN=http://localhost:3000
